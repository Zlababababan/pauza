{
  "manifest_version": 3,
  "name": "Pauza",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "version": "1.0.0",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs",
    "webNavigation",
    "alarms",
    "idle",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Pauza"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["src/pages/interstitial.html", "src/pages/closer.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
